# HELİX-Guard API — environment variables
# Copy to .env and fill in real values before running in production.
# All variables are prefixed with HELIX_

# ── Security ──────────────────────────────────────────────────────────────────
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
HELIX_SECRET_KEY=CHANGE_ME_IN_PRODUCTION_use_openssl_rand_hex_32
HELIX_ALGORITHM=HS256
HELIX_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Database (Faz 6) ─────────────────────────────────────────────────────────
# SQLite (development, default) or PostgreSQL (production).
# Schema is managed by Alembic and applied automatically on API startup —
# no more manually deleting helix.db when models.py changes.
HELIX_DATABASE_URL=sqlite:///./helix.db
# docker compose -f docker-compose.dev.yml up -d   (starts postgres on :5432)
# HELIX_DATABASE_URL=postgresql+psycopg://helix:helix@localhost:5432/helixdb

# ── File storage ──────────────────────────────────────────────────────────────
HELIX_UPLOAD_DIR=./uploads
HELIX_OUTPUT_DIR=./outputs
HELIX_MAX_FILE_SIZE=524288000   # 500 MB in bytes

# ── Scanner ───────────────────────────────────────────────────────────────────
# Set to true to run each scan inside an isolated Docker container
HELIX_USE_DOCKER_SANDBOX=false
HELIX_SCAN_TIMEOUT=300
HELIX_DOCKER_IMAGE=helix-guard-scanner:latest
HELIX_DOCKER_MEMORY=1g
HELIX_DOCKER_CPUS=1.0

# ── Bootstrap admin (created on first start if not exists) ────────────────────
HELIX_ADMIN_USERNAME=admin
HELIX_ADMIN_PASSWORD=changeme
HELIX_ADMIN_EMAIL=admin@helix.local

# ── Faz 5: async job queue ──────────────────────────────────────────────────────
# false (default) = scans run in an in-process thread, no Redis needed.
# true = scans are dispatched to Celery; requires Redis + a running worker:
#   docker compose -f docker-compose.dev.yml up -d
#   celery -A api.celery_app worker --loglevel=info --pool=solo   (Windows)
HELIX_USE_CELERY=false
HELIX_REDIS_URL=redis://localhost:6379/0

# ── Faz 6: object storage ───────────────────────────────────────────────────
# false (default) = firmware files stay on local disk under HELIX_UPLOAD_DIR.
# true = files are stored in MinIO; the worker downloads a temp copy to scan
# and deletes it afterward. Start MinIO with:
#   docker compose -f docker-compose.dev.yml up -d minio
HELIX_USE_OBJECT_STORAGE=false
HELIX_MINIO_ENDPOINT=localhost:9000
HELIX_MINIO_ACCESS_KEY=helixadmin
HELIX_MINIO_SECRET_KEY=helixsecret
HELIX_MINIO_BUCKET=helix-firmware
HELIX_MINIO_SECURE=false
